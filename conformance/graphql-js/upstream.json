{
  "upstream": {
    "repository": "graphql/graphql-js",
    "branch": "17.x.x",
    "version": "17.0.1",
    "branchCommit": "82da713b5941c64a69fa625706788a2b03604362",
    "observedDate": "2026-06-30"
  },
  "testInfrastructure": {
    "runner": "node:test",
    "packageScript": "npm run testonly",
    "packagePattern": "src/**/__tests__/**/*-test.ts",
    "nodeRequirement": "^22.0.0 || ^24.0.0 || ^25.0.0 || >=26.0.0"
  },
  "projection": {
    "data": "ordered response tree",
    "errors": "error count only",
    "scalarValues": "stringified for GraphQL.Execution.ResponseValue.scalar",
    "omitted": [
      "error messages",
      "error paths",
      "error locations",
      "extensions",
      "async scheduling",
      "resolver info objects"
    ]
  },
  "sourceTests": [
    {
      "path": "src/execution/__tests__/directives-test.ts",
      "status": "mirrored",
      "notes": "Only scalar and inline-fragment skip/include cases are mirrored."
    },
    {
      "path": "src/execution/__tests__/executor-test.ts",
      "status": "adapted",
      "notes": "Basic execution cases are adapted to inline-fragment-only, synchronous fixtures."
    },
    {
      "path": "src/execution/__tests__/lists-test.ts",
      "status": "mirrored",
      "notes": "List nullability cases that do not require async iterables or per-item promise rejection are mirrored."
    },
    {
      "path": "src/execution/__tests__/nonnull-test.ts",
      "status": "mirrored",
      "notes": "Null and non-null bubbling shape is mirrored; detailed error payloads are projected to counts."
    },
    {
      "path": "src/execution/__tests__/abstract-test.ts",
      "status": "adapted",
      "notes": "Positive interface runtime-type dispatch is adapted using explicit resolver-owned refs."
    }
  ],
  "skips": [
    "mutation execution",
    "subscription execution",
    "named fragment definitions and fragment spreads",
    "custom directives",
    "input and result coercion diagnostics",
    "request errors",
    "detailed execution error maps",
    "introspection and meta-fields",
    "incremental execution",
    "async iterables",
    "cancellation",
    "resolver info/path metadata",
    "custom scalar serialization"
  ]
}
