{
  "suite": "graphql-js named fragment execution projection",
  "cases": [
    {
      "id": "named_fragment_basic_spread",
      "sourceTest": "src/execution/__tests__/fragments-test.ts",
      "graphqlSource": "{ hero { ...NameFragment } } fragment NameFragment on Character { name }",
      "schema": {
        "queryType": "Query",
        "types": [
          {
            "kind": "object",
            "name": "Query",
            "fields": [
              { "name": "hero", "type": { "kind": "named", "name": "Character" } }
            ]
          },
          {
            "kind": "object",
            "name": "Character",
            "fields": [
              { "name": "name", "type": { "kind": "named", "name": "String" } }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "Query",
        "fragmentDefinitions": [
          {
            "name": "NameFragment",
            "typeCondition": "Character",
            "selectionSet": [
              { "kind": "field", "responseName": "name", "fieldName": "name" }
            ]
          }
        ],
        "selectionSet": [
          {
            "kind": "field",
            "responseName": "hero",
            "fieldName": "hero",
            "selectionSet": [
              { "kind": "fragmentSpread", "fragmentName": "NameFragment" }
            ]
          }
        ]
      },
      "source": { "kind": "object", "typeName": "Query", "ref": "root" },
      "resolvers": [
        {
          "parentType": "Query",
          "fieldName": "hero",
          "sourceRef": "root",
          "returns": { "kind": "object", "typeName": "Character", "ref": "hero" }
        },
        {
          "parentType": "Character",
          "fieldName": "name",
          "sourceRef": "hero",
          "returns": { "kind": "scalar", "value": "Leia" }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [
            {
              "name": "hero",
              "value": {
                "kind": "object",
                "fields": [
                  { "name": "name", "value": { "kind": "scalar", "value": "Leia" } }
                ]
              }
            }
          ]
        },
        "errorCount": 0
      }
    }
  ]
}
