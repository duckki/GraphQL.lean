    {
      "id": "abstract_interface_inline_fragments",
      "sourceTest": "src/execution/__tests__/abstract-test.ts",
      "graphqlSource": "{ pets { name ... on Dog { woofs } ... on Cat { meows } } }",
      "schema": {
        "queryType": "Query",
        "types": [
          {
            "kind": "interface",
            "name": "Pet",
            "fields": [
              { "name": "name", "type": { "kind": "named", "name": "String" } }
            ]
          },
          {
            "kind": "object",
            "name": "Dog",
            "interfaces": ["Pet"],
            "fields": [
              { "name": "name", "type": { "kind": "named", "name": "String" } },
              { "name": "woofs", "type": { "kind": "named", "name": "String" } }
            ]
          },
          {
            "kind": "object",
            "name": "Cat",
            "interfaces": ["Pet"],
            "fields": [
              { "name": "name", "type": { "kind": "named", "name": "String" } },
              { "name": "meows", "type": { "kind": "named", "name": "String" } }
            ]
          },
          {
            "kind": "object",
            "name": "Query",
            "fields": [
              {
                "name": "pets",
                "type": {
                  "kind": "list",
                  "of": { "kind": "named", "name": "Pet" }
                }
              }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "Query",
        "selectionSet": [
          {
            "kind": "field",
            "responseName": "pets",
            "fieldName": "pets",
            "selectionSet": [
              { "kind": "field", "responseName": "name", "fieldName": "name" },
              {
                "kind": "inlineFragment",
                "typeCondition": "Dog",
                "selectionSet": [
                  { "kind": "field", "responseName": "woofs", "fieldName": "woofs" }
                ]
              },
              {
                "kind": "inlineFragment",
                "typeCondition": "Cat",
                "selectionSet": [
                  { "kind": "field", "responseName": "meows", "fieldName": "meows" }
                ]
              }
            ]
          }
        ]
      },
      "source": { "kind": "object", "typeName": "Query", "ref": "root" },
      "resolvers": [
        {
          "parentType": "Query",
          "fieldName": "pets",
          "sourceRef": "root",
          "returns": {
            "kind": "list",
            "values": [
              { "kind": "object", "typeName": "Dog", "ref": "dog" },
              { "kind": "object", "typeName": "Cat", "ref": "cat" }
            ]
          }
        },
        {
          "parentType": "Dog",
          "fieldName": "name",
          "sourceRef": "dog",
          "returns": { "kind": "scalar", "value": "Odie" }
        },
        {
          "parentType": "Dog",
          "fieldName": "woofs",
          "sourceRef": "dog",
          "returns": { "kind": "scalar", "value": "true" }
        },
        {
          "parentType": "Cat",
          "fieldName": "name",
          "sourceRef": "cat",
          "returns": { "kind": "scalar", "value": "Garfield" }
        },
        {
          "parentType": "Cat",
          "fieldName": "meows",
          "sourceRef": "cat",
          "returns": { "kind": "scalar", "value": "false" }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [
            {
              "name": "pets",
              "value": {
                "kind": "list",
                "values": [
                  {
                    "kind": "object",
                    "fields": [
                      { "name": "name", "value": { "kind": "scalar", "value": "Odie" } },
                      { "name": "woofs", "value": { "kind": "scalar", "value": "true" } }
                    ]
                  },
                  {
                    "kind": "object",
                    "fields": [
                      { "name": "name", "value": { "kind": "scalar", "value": "Garfield" } },
                      { "name": "meows", "value": { "kind": "scalar", "value": "false" } }
                    ]
                  }
                ]
              }
            }
          ]
        },
        "errorCount": 0
      }
    }
  ]
