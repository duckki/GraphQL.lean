{
  "name": "graphql-lean-conformance",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^25.0.0 || >=26.0.0"
  },
  "devDependencies": {
    "graphql": "17.0.1"
  },
  "scripts": {
    "gen:graphql-js": "node scripts/gen-graphql-js-conformance.mjs",
    "gen:graphql-js:named-fragment": "node scripts/gen-graphql-js-conformance.mjs --cases graphql-js/named-fragment-cases --target named-fragment",
    "oracle:graphql-js": "node scripts/graphql-js-oracle.mjs --check",
    "oracle:graphql-js:named-fragment": "node scripts/graphql-js-oracle.mjs --cases graphql-js/named-fragment-cases --check"
  }
}
