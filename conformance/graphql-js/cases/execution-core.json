{
  "suite": "graphql-js execution core projection",
  "cases": [
    {
      "id": "directives_scalar_include_false",
      "sourceTest": "src/execution/__tests__/directives-test.ts",
      "graphqlSource": "{ a b @include(if: false) }",
      "schema": {
        "queryType": "Query",
        "types": [
          {
            "kind": "object",
            "name": "Query",
            "fields": [
              { "name": "a", "type": { "kind": "named", "name": "String" } },
              { "name": "b", "type": { "kind": "named", "name": "String" } }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "Query",
        "selectionSet": [
          { "kind": "field", "responseName": "a", "fieldName": "a" },
          {
            "kind": "field",
            "responseName": "b",
            "fieldName": "b",
            "directives": [
              { "kind": "include", "if": { "kind": "boolean", "value": false } }
            ]
          }
        ]
      },
      "source": { "kind": "object", "typeName": "Query", "ref": "root" },
      "resolvers": [
        {
          "parentType": "Query",
          "fieldName": "a",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "a" }
        },
        {
          "parentType": "Query",
          "fieldName": "b",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "b" }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [{ "name": "a", "value": { "kind": "scalar", "value": "a" } }]
        },
        "errorCount": 0
      }
    },
    {
      "id": "directives_inline_fragment_skip_false",
      "sourceTest": "src/execution/__tests__/directives-test.ts",
      "graphqlSource": "{ a ... on Query @skip(if: false) { b } }",
      "schema": {
        "queryType": "Query",
        "types": [
          {
            "kind": "object",
            "name": "Query",
            "fields": [
              { "name": "a", "type": { "kind": "named", "name": "String" } },
              { "name": "b", "type": { "kind": "named", "name": "String" } }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "Query",
        "selectionSet": [
          { "kind": "field", "responseName": "a", "fieldName": "a" },
          {
            "kind": "inlineFragment",
            "typeCondition": "Query",
            "directives": [
              { "kind": "skip", "if": { "kind": "boolean", "value": false } }
            ],
            "selectionSet": [
              { "kind": "field", "responseName": "b", "fieldName": "b" }
            ]
          }
        ]
      },
      "source": { "kind": "object", "typeName": "Query", "ref": "root" },
      "resolvers": [
        {
          "parentType": "Query",
          "fieldName": "a",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "a" }
        },
        {
          "parentType": "Query",
          "fieldName": "b",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "b" }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [
            { "name": "a", "value": { "kind": "scalar", "value": "a" } },
            { "name": "b", "value": { "kind": "scalar", "value": "b" } }
          ]
        },
        "errorCount": 0
      }
    },
    {
      "id": "directives_anonymous_inline_fragment_include_variable",
      "sourceTest": "src/execution/__tests__/directives-test.ts",
      "graphqlSource": "query ($withB: Boolean!) { a ... @include(if: $withB) { b } }",
      "schema": {
        "queryType": "Query",
        "types": [
          {
            "kind": "object",
            "name": "Query",
            "fields": [
              { "name": "a", "type": { "kind": "named", "name": "String" } },
              { "name": "b", "type": { "kind": "named", "name": "String" } }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "Query",
        "variableDefinitions": [
          {
            "name": "withB",
            "type": {
              "kind": "nonNull",
              "of": { "kind": "named", "name": "Boolean" }
            }
          }
        ],
        "selectionSet": [
          { "kind": "field", "responseName": "a", "fieldName": "a" },
          {
            "kind": "inlineFragment",
            "directives": [
              { "kind": "include", "if": { "kind": "variable", "name": "withB" } }
            ],
            "selectionSet": [
              { "kind": "field", "responseName": "b", "fieldName": "b" }
            ]
          }
        ]
      },
      "variables": [{ "name": "withB", "value": { "kind": "boolean", "value": true } }],
      "source": { "kind": "object", "typeName": "Query", "ref": "root" },
      "resolvers": [
        {
          "parentType": "Query",
          "fieldName": "a",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "a" }
        },
        {
          "parentType": "Query",
          "fieldName": "b",
          "sourceRef": "root",
          "returns": { "kind": "scalar", "value": "b" }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [
            { "name": "a", "value": { "kind": "scalar", "value": "a" } },
            { "name": "b", "value": { "kind": "scalar", "value": "b" } }
          ]
        },
        "errorCount": 0
      }
    },
    {
      "id": "nested_objects_aliases_and_lists",
      "sourceTest": "src/execution/__tests__/executor-test.ts",
      "graphqlSource": "{ a b x: c f deep { a b c deeper { a b } } }",
      "schema": {
        "queryType": "DataType",
        "types": [
          {
            "kind": "object",
            "name": "DataType",
            "fields": [
              { "name": "a", "type": { "kind": "named", "name": "String" } },
              { "name": "b", "type": { "kind": "named", "name": "String" } },
              { "name": "c", "type": { "kind": "named", "name": "String" } },
              { "name": "f", "type": { "kind": "named", "name": "String" } },
              { "name": "deep", "type": { "kind": "named", "name": "DeepDataType" } }
            ]
          },
          {
            "kind": "object",
            "name": "DeepDataType",
            "fields": [
              { "name": "a", "type": { "kind": "named", "name": "String" } },
              { "name": "b", "type": { "kind": "named", "name": "String" } },
              {
                "name": "c",
                "type": {
                  "kind": "list",
                  "of": { "kind": "named", "name": "String" }
                }
              },
              {
                "name": "deeper",
                "type": {
                  "kind": "list",
                  "of": { "kind": "named", "name": "DataType" }
                }
              }
            ]
          }
        ]
      },
      "operation": {
        "rootType": "DataType",
        "selectionSet": [
          { "kind": "field", "responseName": "a", "fieldName": "a" },
          { "kind": "field", "responseName": "b", "fieldName": "b" },
          { "kind": "field", "responseName": "x", "fieldName": "c" },
          { "kind": "field", "responseName": "f", "fieldName": "f" },
          {
            "kind": "field",
            "responseName": "deep",
            "fieldName": "deep",
            "selectionSet": [
              { "kind": "field", "responseName": "a", "fieldName": "a" },
              { "kind": "field", "responseName": "b", "fieldName": "b" },
              { "kind": "field", "responseName": "c", "fieldName": "c" },
              {
                "kind": "field",
                "responseName": "deeper",
                "fieldName": "deeper",
                "selectionSet": [
                  { "kind": "field", "responseName": "a", "fieldName": "a" },
                  { "kind": "field", "responseName": "b", "fieldName": "b" }
                ]
              }
            ]
          }
        ]
      },
      "source": { "kind": "object", "typeName": "DataType", "ref": "data" },
      "resolvers": [
        {
          "parentType": "DataType",
          "fieldName": "a",
          "sourceRef": "data",
          "returns": { "kind": "scalar", "value": "Apple" }
        },
        {
          "parentType": "DataType",
          "fieldName": "b",
          "sourceRef": "data",
          "returns": { "kind": "scalar", "value": "Banana" }
        },
        {
          "parentType": "DataType",
          "fieldName": "c",
          "sourceRef": "data",
          "returns": { "kind": "scalar", "value": "Cookie" }
        },
        {
          "parentType": "DataType",
          "fieldName": "f",
          "sourceRef": "data",
          "returns": { "kind": "scalar", "value": "Fish" }
        },
        {
          "parentType": "DataType",
          "fieldName": "deep",
          "sourceRef": "data",
          "returns": { "kind": "object", "typeName": "DeepDataType", "ref": "deep" }
        },
        {
          "parentType": "DeepDataType",
          "fieldName": "a",
          "sourceRef": "deep",
          "returns": { "kind": "scalar", "value": "Already Been Done" }
        },
        {
          "parentType": "DeepDataType",
          "fieldName": "b",
          "sourceRef": "deep",
          "returns": { "kind": "scalar", "value": "Boring" }
        },
        {
          "parentType": "DeepDataType",
          "fieldName": "c",
          "sourceRef": "deep",
          "returns": {
            "kind": "list",
            "values": [
              { "kind": "scalar", "value": "Contrived" },
              { "kind": "null" },
              { "kind": "scalar", "value": "Confusing" }
            ]
          }
        },
        {
          "parentType": "DeepDataType",
          "fieldName": "deeper",
          "sourceRef": "deep",
          "returns": {
            "kind": "list",
            "values": [
              { "kind": "object", "typeName": "DataType", "ref": "data" },
              { "kind": "null" },
              { "kind": "object", "typeName": "DataType", "ref": "data" }
            ]
          }
        }
      ],
      "expected": {
        "data": {
          "kind": "object",
          "fields": [
            { "name": "a", "value": { "kind": "scalar", "value": "Apple" } },
            { "name": "b", "value": { "kind": "scalar", "value": "Banana" } },
            { "name": "x", "value": { "kind": "scalar", "value": "Cookie" } },
            { "name": "f", "value": { "kind": "scalar", "value": "Fish" } },
            {
              "name": "deep",
              "value": {
                "kind": "object",
                "fields": [
                  {
                    "name": "a",
                    "value": { "kind": "scalar", "value": "Already Been Done" }
                  },
                  { "name": "b", "value": { "kind": "scalar", "value": "Boring" } },
                  {
                    "name": "c",
                    "value": {
                      "kind": "list",
                      "values": [
                        { "kind": "scalar", "value": "Contrived" },
                        { "kind": "null" },
                        { "kind": "scalar", "value": "Confusing" }
                      ]
                    }
                  },
                  {
                    "name": "deeper",
                    "value": {
                      "kind": "list",
                      "values": [
                        {
                          "kind": "object",
                          "fields": [
                            { "name": "a", "value": { "kind": "scalar", "value": "Apple" } },
                            { "name": "b", "value": { "kind": "scalar", "value": "Banana" } }
                          ]
                        },
                        { "kind": "null" },
                        {
                          "kind": "object",
                          "fields": [
                            { "name": "a", "value": { "kind": "scalar", "value": "Apple" } },
                            { "name": "b", "value": { "kind": "scalar", "value": "Banana" } }
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        },
        "errorCount": 0
      }
    },
